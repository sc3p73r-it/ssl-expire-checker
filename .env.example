# Supabase Postgres connection string (Settings → Database → URI, use pooler on port 6543 for serverless-friendly pooling)
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# Supabase project URL (Settings → API → Project URL)
SUPABASE_PROJECT_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable key (Settings → API → Publishable / anon key — safe for browsers)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx_or_anon_jwt

# JWT secret used to verify access tokens server-side (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# Allowed CORS origins for browser frontend (comma-separated)
# Example: https://your-app.vercel.app,http://localhost:8080
FRONTEND_ORIGINS=*

# Optional: Slack (hooks.slack.com) or Discord (discord.com/api/webhooks/...) webhook URL
WEBHOOK_URL=

# Days before expiry to mark a certificate as "expiring" (yellow)
EXPIRY_THRESHOLD_DAYS=15

# Background full-scan interval in hours
SCAN_INTERVAL_HOURS=12

# Concurrent TLS workers
WORKER_COUNT=10

PORT=8080
